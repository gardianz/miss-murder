# Template env — SALIN ke .env lalu isi. File .env TIDAK di-commit (gitignore).
#   cp .env.example .env   &&   nano .env
# Bot listing_bot.py auto-baca .env (KEY=VALUE, tanpa spasi di sekitar '=').

# ── Telegram alert (opsional) ──
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789
# TG_PER_SUBMIT=0   # 0 = ringkasan window saja (fleet besar, hindari 100+ pesan/window). default 1 = alert tiap submit

# ── Register access code (server WAJIB, dari developer Edel) ──
# REG_ACCESS_CODE=xxxxxxxx   # dipakai register_http.py; watcher isi ini otomatis dari channel

# ── Watcher Telegram (edel_watch.py) — auto-tangkap access code dari channel ──
# EDEL_TG_API_ID=123456                 # dari https://my.telegram.org (wajib)
# EDEL_TG_API_HASH=xxxxxxxxxxxxxxxx     # dari https://my.telegram.org (wajib)
# EDEL_TG_WATCH=handlpay,oneswap_community,edeldotfinance   # channel dipantau (pisah koma = multi)
# EDEL_TG_NOTIFY=me                     # tujuan notif kalau tanpa bot (default me)
# EDEL_CODE_USES=1                      # berapa akun di-register per kode (1 = kode single-use)
# EDEL_PROBE=0                          # 1 = cek kode dulu sblm register (matikan utk kode single-use)
# EDEL_CODE_RE=                         # regex custom akses-kode (group 1). kosong = 3 pola bawaan
# EDEL_TG_POLL=1.0                      # detik antar poll getHistory (0=off)
# EDEL_TG_CATCHUP=0                     # scan N pesan terakhir saat start
# Notif watcher pakai TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID di atas (andal). Kosong = Telethon 'me'.

# ── Tuning daemon (opsional; override default) ──
# HTTP_READ_TO=75      # read timeout detik (POST prepare edel ~50s -> pasang tinggi biar tak retry-ganda)
# API_DEADLINE=120     # budget total per request
# WORKERS=6            # paralel; kecil (4-6) tekan FAILED (VAULT_V6_PQS timeout)
# AUTO_POLL_FAST=25
# NO_PROXY=1           # paksa koneksi langsung (abaikan proxy)
